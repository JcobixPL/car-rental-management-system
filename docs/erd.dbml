Enum UserRole {
  Administrator
  Employee
  Customer
}

Enum CustomerStatus {
  Active
  Blocked
  Blacklisted
  Anonymized
}

Table UserAccounts {
  Id uuid [pk]
  Username varchar(100) [not null, unique]
  Email varchar(255) [unique]
  Role UserRole [not null]
  IsActive boolean [not null, default: true]
  CreatedAt timestamp [not null]
}

Table Branches {
  Id uuid [pk]
  Name varchar(150) [not null]
  City varchar(100) [not null]
  Address varchar(255) [not null]
  PhoneNumber varchar(30)]
  Email varchar(255)
  IsActive boolean [not null, default: true]
}

Table Employees {
  Id uuid [pk]
  UserAccountId uuid [not null, unique]
  BranchId uuid [not null]
  FirstName varchar(100) [not null]
  LastName varchar(100) [not null]
  IsActive boolean [not null, default: true]
}

Table Customers {
  Id uuid [pk]
  UserAccountId uuid [unique]
  FirstName varchar(100) [not null]
  LastName varchar(100) [not null]
  Email varchar(255) [not null]
  PhoneNumber varchar(30) [not null]
  DateOfBirth date
  Status CustomerStatus [not null]
  CreatedAt timestamp [not null]
}

Table BranchOpeningHours {
  Id uuid [pk]
  BranchId uuid [not null]
  DayOfWeek int [not null]
  IsClosed boolean [not null, default: false]
  OpensAt time
  ClosesAt time

  indexes {
    (BranchId, DayOfWeek) [unique]
  }
}

Table BranchOpeningHoursExceptions {
  Id uuid [pk]
  BranchId uuid [not null]
  Date date [not null]
  IsClosed boolean [not null, default: false]
  OpensAt time
  ClosesAt time

  indexes {
    (BranchId, Date) [unique]
  }
}

Ref: Employees.UserAccountId - UserAccounts.Id
Ref: Employees.BranchId > Branches.Id
Ref: Customers.UserAccountId - UserAccounts.Id
Ref: BranchOpeningHours.BranchId > Branches.Id
Ref: BranchOpeningHoursExceptions.BranchId > Branches.Id
